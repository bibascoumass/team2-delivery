<launch>
  <arg name="initial_x"   default="0.0"/>
  <arg name="initial_y"   default="0.0"/>
  <arg name="initial_yaw" default="0.0"/>
  <arg name="use_explore" default="true"/>
  <arg name="open_rviz"   default="false"/>

  <!-- Make both the Triton model and turtlebot3_house model discoverable by Gazebo -->
  <env name="GAZEBO_MODEL_PATH"
       value="$(find team2_delivery)/models:$(find turtlebot3_gazebo)/models:$(optenv GAZEBO_MODEL_PATH)"/>

  <!-- Gazebo with the restaurant world -->
  <include file="$(find gazebo_ros)/launch/empty_world.launch">
    <arg name="world_name" value="$(find team2_delivery)/world/turtlebot3_house.world"/>
    <arg name="paused"     value="false"/>
    <arg name="use_sim_time" value="true"/>
    <arg name="gui"        value="true"/>
    <arg name="headless"   value="false"/>
    <arg name="debug"      value="false"/>
  </include>

  <!-- Spawn the Triton robot -->
  <node pkg="gazebo_ros" type="spawn_model" name="spawn_triton" output="screen"
        args="-sdf
              -model triton
              -file $(find team2_delivery)/models/triton/model.sdf
              -x $(arg initial_x)
              -y $(arg initial_y)
              -z 0.05
              -Y $(arg initial_yaw)"/>

  <!-- Ground-truth odometry from Gazebo -->
  <node pkg="team2_delivery" type="position_publisher.py" name="position_publisher" output="screen"/>

  <!-- Relay /cmd_vel → /robot_cmd_vel for the Gazebo motion plugin -->
  <node pkg="topic_tools" type="relay" name="cmd_vel_relay" output="screen"
        args="/cmd_vel /robot_cmd_vel"/>

  <!-- Static TFs: base_link → base_scan (LIDAR at z=0.161) -->
  <node pkg="tf" type="static_transform_publisher" name="base_to_laser"
        args="0 0 0.161 0 0 0 base_link base_scan 50"/>

  <!-- Static TFs: base_link → camera_link -->
  <node pkg="tf" type="static_transform_publisher" name="base_to_camera"
        args="0.05 0 0.15 0 0 0 base_link camera_link 50"/>

  <!-- GMapping SLAM -->
  <node pkg="gmapping" type="slam_gmapping" name="slam_gmapping" output="screen">
    <param name="base_frame"          value="base_link"/>
    <param name="odom_frame"          value="odom"/>
    <param name="map_frame"           value="map"/>
    <param name="map_update_interval" value="1.0"/>
    <param name="maxUrange"           value="3.0"/>
    <param name="sigma"               value="0.05"/>
    <param name="kernelSize"          value="1"/>
    <param name="lstep"               value="0.05"/>
    <param name="astep"               value="0.05"/>
    <param name="iterations"          value="5"/>
    <param name="lsigma"              value="0.075"/>
    <param name="ogain"               value="3.0"/>
    <param name="lskip"               value="0"/>
    <param name="minimumScore"        value="50"/>
    <param name="srr"                 value="0.1"/>
    <param name="srt"                 value="0.2"/>
    <param name="str"                 value="0.1"/>
    <param name="stt"                 value="0.2"/>
    <param name="linearUpdate"        value="0.2"/>
    <param name="angularUpdate"       value="0.2"/>
    <param name="temporalUpdate"      value="0.5"/>
    <param name="resampleThreshold"   value="0.5"/>
    <param name="particles"           value="100"/>
    <param name="xmin"                value="-10.0"/>
    <param name="ymin"                value="-10.0"/>
    <param name="xmax"                value="10.0"/>
    <param name="ymax"                value="10.0"/>
    <param name="delta"               value="0.05"/>
    <param name="llsamplerange"       value="0.01"/>
    <param name="llsamplestep"        value="0.01"/>
    <param name="lasamplerange"       value="0.005"/>
    <param name="lasamplestep"        value="0.005"/>
  </node>

  <!-- Navigation for autonomous exploration (static_map: false for mapping) -->
  <node pkg="move_base" type="move_base" name="move_base" output="screen">
    <rosparam file="$(find team2_delivery)/config/move_base_mapping.yaml" command="load"/>
    <remap from="cmd_vel" to="/cmd_vel"/>
  </node>

  <!-- Optional autonomous frontier exploration -->
  <node if="$(arg use_explore)" pkg="explore_lite" type="explore" name="explore" output="screen">
    <param name="robot_base_frame"      value="base_link"/>
    <param name="costmap_topic"         value="/move_base/global_costmap/costmap"/>
    <param name="costmap_updates_topic" value="/move_base/global_costmap/costmap_updates"/>
    <param name="planner_frequency"     value="0.25"/>
    <param name="progress_timeout"      value="20.0"/>
    <param name="min_frontier_size"     value="0.35"/>
    <param name="potential_scale"       value="2.5"/>
    <param name="gain_scale"            value="1.0"/>
    <param name="orientation_scale"     value="0.0"/>
    <param name="visualize"             value="true"/>
    <param name="transform_tolerance"   value="0.5"/>
  </node>

  <node if="$(arg open_rviz)" pkg="rviz" type="rviz" name="rviz"
        args="-d $(find team2_delivery)/config/robot.rviz" output="screen"/>
</launch>
