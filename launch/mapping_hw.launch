<launch>
  <arg name="lidar_port" default="/dev/serial/by-id/usb-Silicon_Labs_CP2102_USB_to_UART_Bridge_976e12c989fada42b9c68328c6855255-if00-port0"/>
  <arg name="lidar_baud" default="256000"/>
  <arg name="base_port" default="/dev/serial/by-id/usb-Arduino__www.arduino.cc__0042_14235303036351915001-if00"/>
  <arg name="base_baud" default="115200"/>
  <arg name="start_rplidar" default="true"/>
  <arg name="start_rosserial_base" default="true"/>
  <arg name="use_saved_map" default="true"/>
  <arg name="use_explore" default="false"/>
  <arg name="open_rviz" default="false"/>
  <arg name="cmd_vel_topic" default="/nav_cmd_vel"/> 
  <arg name="map_file" default="/home/triton/catkin_ws/my_map_explore.yaml"/>
  <arg name="initial_x" default="0.0"/>
  <arg name="initial_y" default="0.0"/>
  <arg name="initial_yaw" default="0.0"/>

  <rosparam file="$(find team2_delivery)/config/table_locations.yaml" command="load"/>
  <param name="/use_sim_time" value="false"/>

  <arg name="image_topic" default="/camera/color/image_raw"/>
  <arg name="depth_topic" default="/camera/depth/image_rect_raw"/>

  <arg name="camera" default="true"/>
  <group if="$(arg camera)">
	  <include file="$(find realsense2_camera)/launch/rs_aligned_depth.launch" />
  </group>

  <node if="$(arg start_rplidar)" pkg="rplidar_ros" type="rplidarNode" name="rplidar" output="screen">
    <param name="serial_port"      value="$(arg lidar_port)"/>
    <param name="serial_baudrate"  value="$(arg lidar_baud)"/>
    <param name="frame_id"         value="base_scan"/>
    <param name="inverted"         value="false"/>
    <param name="angle_compensate" value="true"/>
  </node>

  <node pkg="tf" type="static_transform_publisher" name="base_link_to_base_scan"
        args="0 0 0.161 0 0 0 base_link base_scan 100"/>

  <node pkg="tf" type="static_transform_publisher" name="base_link_to_camera_link_static"
        args="0.09 0 0.25 0 0 0 base_link camera_link 100"/>

  <node if="$(arg start_rosserial_base)" pkg="rosserial_python" type="serial_node.py"
        name="arduino_base" output="screen">
    <param name="port" value="$(arg base_port)"/>
    <param name="baud" value="$(arg base_baud)"/>
  </node>

  <!-- <node pkg="team2_delivery" type="tf_to_odom.py" name="tf_to_odom"
        output="screen">
    <param name="odom_frame" value="odom"/>
    <param name="base_frame" value="base_link"/>
    <param name="rate_hz" value="30.0"/>
  </node> -->

  <!-- Saved-map mode for delivery/search: publish the saved map and localize with AMCL. -->
  <group if="$(arg use_saved_map)">
    <node pkg="map_server" type="map_server" name="map_server"
          args="$(arg map_file)" output="screen"/>

    <node pkg="amcl" type="amcl" name="amcl" output="screen">
      <rosparam file="$(find team2_delivery)/config/amcl.yaml" command="load"/>
      <param name="initial_pose_x" value="$(arg initial_x)"/>
      <param name="initial_pose_y" value="$(arg initial_y)"/>
      <param name="initial_pose_a" value="$(arg initial_yaw)"/>
    </node>
  </group>

  <!-- Mapping mode: use gmapping, optionally with explore_lite. -->
  <group unless="$(arg use_saved_map)">
    <node pkg="gmapping" type="slam_gmapping" name="slam_gmapping" output="log"
          launch-prefix="bash -c 'exec 2&gt;/dev/null; exec &quot;$@&quot;' bash">
      <param name="base_frame"         value="base_link"/>
      <param name="odom_frame"         value="odom"/>
      <param name="map_frame"          value="map"/>
      <param name="map_update_interval" value="1.0"/>
      <param name="maxUrange"          value="8.0"/>
      <param name="sigma"              value="0.05"/>
      <param name="kernelSize"         value="1"/>
      <param name="lstep"              value="0.05"/>
      <param name="astep"              value="0.05"/>
      <param name="iterations"         value="5"/>
      <param name="lsigma"             value="0.075"/>
      <param name="ogain"              value="3.0"/>
      <param name="lskip"              value="0"/>
      <param name="minimumScore"       value="50"/>
      <param name="srr"                value="0.1"/>
      <param name="srt"                value="0.2"/>
      <param name="str"                value="0.1"/>
      <param name="stt"                value="0.2"/>
      <param name="linearUpdate"       value="0.2"/>
      <param name="angularUpdate"      value="0.2"/>
      <param name="temporalUpdate"     value="0.5"/>
      <param name="resampleThreshold"  value="0.5"/>
      <param name="particles"          value="100"/>
      <param name="xmin"               value="-10.0"/>
      <param name="ymin"               value="-10.0"/>
      <param name="xmax"               value="10.0"/>
      <param name="ymax"               value="10.0"/>
      <param name="delta"              value="0.05"/>
      <param name="llsamplerange"      value="0.01"/>
      <param name="llsamplestep"       value="0.01"/>
      <param name="lasamplerange"      value="0.005"/>
      <param name="lasamplestep"       value="0.005"/>
      <remap from="scan" to="/scan"/>
    </node>

    <node if="$(arg use_explore)" pkg="explore_lite" type="explore" name="explore" output="screen">
      <param name="robot_base_frame"      value="base_link"/>
      <param name="costmap_topic"         value="/move_base/global_costmap/costmap"/>
      <param name="costmap_updates_topic" value="/move_base/global_costmap/costmap_updates"/>
      <param name="planner_frequency"     value="0.25"/>
      <param name="progress_timeout"      value="20.0"/>
      <param name="min_frontier_size"     value="0.35"/>
      <param name="potential_scale"       value="2.5"/>
      <param name="gain_scale"            value="1.0"/>
      <param name="orientation_scale"     value="0.0"/>
      <param name="visualize"             value="true"/>
      <param name="transform_tolerance"   value="0.5"/>
    </node>
  </group>

  <node if="$(arg use_saved_map)" pkg="move_base" type="move_base" name="move_base" output="screen">
    <rosparam file="$(find team2_delivery)/config/move_base_delivery_hw.yaml" command="load"/>
    <remap from="cmd_vel" to="$(arg cmd_vel_topic)"/>
  </node>

  <node unless="$(arg use_saved_map)" pkg="move_base" type="move_base" name="move_base" output="screen">
    <rosparam file="$(find team2_delivery)/config/move_base_mapping_hw.yaml" command="load"/>
    <remap from="cmd_vel" to="$(arg cmd_vel_topic)"/>
  </node>

  <!-- <node pkg="team2_delivery" type="map_quality_monitor.py" name="map_quality_monitor" output="screen"/> -->

  <node if="$(arg open_rviz)" pkg="rviz" type="rviz" name="rviz"
        args="-d $(find team2_delivery)/config/robot.rviz" output="screen"/>
</launch>
